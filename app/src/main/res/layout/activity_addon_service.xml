<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/skyline_bg">

    <!-- HEADER CỐ ĐỊNH -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/skyline_blue_dark"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="6dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvFlightNumberHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHUYẾN BAY"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvHeaderSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DỊCH VỤ BỔ SUNG"
                    android:textColor="#B3FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="32dp" android:layout_height="32dp" />
        </LinearLayout>

        <!-- THÔNG TIN CHUYẾN BAY LƯỢT ĐI -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFlightOutbound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/skyline_blue_dark"
            app:strokeColor="#22FFFFFF"
            app:strokeWidth="1dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="16dp"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvDepCode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="26sp" android:textStyle="bold" android:text="SGN" />
                    <TextView android:id="@+id/tvDepTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:text="05:45" />
                    <TextView android:id="@+id/tvDepDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="28 Th06" android:textColor="#CCFFFFFF" android:textSize="11sp" />
                    <TextView android:id="@+id/tvDepAirport" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="TÂN SƠN NHẤT" android:textColor="#80FFFFFF" android:textSize="9sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp">

                    <TextView
                        android:id="@+id/tvFlightNumberOut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VN123"
                        android:textColor="#B3FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/imgPlane"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="4dp"
                        android:rotation="90"
                        android:src="@drawable/ic_plane"
                        app:tint="@color/white"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tvDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="1g 10p"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvArrCode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="26sp" android:textStyle="bold" android:text="HAN" />
                    <TextView android:id="@+id/tvArrTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:text="07:55" />
                    <TextView android:id="@+id/tvArrDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="28 Th06" android:textColor="#CCFFFFFF" android:textSize="11sp" />
                    <TextView android:id="@+id/tvArrAirport" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="NỘI BÀI" android:textColor="#80FFFFFF" android:textSize="9sp" android:textStyle="bold" android:gravity="end" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- THÔNG TIN CHUYẾY BAY LƯỢT VỀ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFlightReturn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/skyline_blue_dark"
            app:strokeColor="#22FFFFFF"
            app:strokeWidth="1dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="16dp"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvDepCodeReturn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="26sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvDepTimeReturn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvDepDateReturn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#CCFFFFFF" android:textSize="11sp" />
                    <TextView android:id="@+id/tvDepAirportReturn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:textColor="#80FFFFFF" android:textSize="9sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp">

                    <TextView
                        android:id="@+id/tvFlightNumberRet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#B3FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/imgPlaneReturn"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="4dp"
                        android:rotation="270"
                        android:src="@drawable/ic_plane"
                        app:tint="@color/white"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tvDurationReturn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvArrCodeReturn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="26sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvArrTimeReturn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvArrDateReturn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#CCFFFFFF" android:textSize="11sp" />
                    <TextView android:id="@+id/tvArrAirportReturn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:textColor="#80FFFFFF" android:textSize="9sp" android:textStyle="bold" android:gravity="end" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- NỘI DUNG CUỘN -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- INFO BAR -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@color/skyline_blue_dark"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="ⓘ  Chọn thêm dịch vụ để cá nhân hóa hành trình của bạn."
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- KIỂU 1: 1 NGƯỜI 1 CHIỀU (DẠNG DANH SÁCH CŨ) -->
            <LinearLayout
                android:id="@+id/layoutSinglePaxOneWay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/itemSeatSingle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="20dp"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="14dp"
                        app:cardBackgroundColor="@color/skyline_blue_light"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp"
                            android:src="@drawable/ic_seat"
                            app:tint="@color/skyline_blue"
                            android:contentDescription="@null" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/skyline_blue_dark"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:text="Ghế ngồi" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/skyline_text_secondary"
                            android:textSize="13sp"
                            android:text="Chọn chỗ ngồi yêu thích để có chuyến bay thoải mái hơn." />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSelectSeatSingle"
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="Chọn"
                        android:textColor="@color/skyline_blue"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <LinearLayout
                    android:id="@+id/itemBaggageSingle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="20dp"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="14dp"
                        app:cardBackgroundColor="@color/skyline_blue_light"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp"
                            android:src="@drawable/ic_baggage_big"
                            app:tint="@color/skyline_blue"
                            android:contentDescription="@null" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/skyline_blue_dark"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:text="Hành lý" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/skyline_text_secondary"
                            android:textSize="13sp"
                            android:text="Thêm hành lý dễ dàng với mức giá ưu đãi trước chuyến đi." />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSelectBaggageSingle"
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="Chọn"
                        android:textColor="@color/skyline_blue"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- KIỂU 2: NHIỀU NGƯỜI HOẶC KHỨ HỒI (DẠNG THẺ CARD) -->
            <LinearLayout
                android:id="@+id/layoutMultiPaxOrRoundTrip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="visible">

                <!-- LƯỢT ĐI -->
                <TextView
                    android:id="@+id/tvLabelOutbound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LƯỢT ĐI"
                    android:textColor="@color/skyline_teal"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:id="@+id/containerOutbound"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- LƯỢT VỀ -->
                <LinearLayout
                    android:id="@+id/layoutReturnSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#F3F4F6" android:layout_marginHorizontal="-16dp" android:layout_marginBottom="24dp"/>

                    <TextView
                        android:id="@+id/tvLabelReturn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LƯỢT VỀ"
                        android:textColor="@color/skyline_teal"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:id="@+id/containerReturn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM BAR -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/white"
        app:cardElevation="20dp"
        app:cardCornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingVertical="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TỔNG CHI PHÍ"
                    android:textColor="@color/skyline_text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/txtTotalPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 VND"
                    android:textColor="@color/skyline_blue_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                android:layout_width="140dp"
                android:layout_height="52dp"
                android:text="Tiếp tục  →"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/skyline_blue_dark"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
