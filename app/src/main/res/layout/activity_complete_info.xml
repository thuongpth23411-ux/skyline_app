<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_screen">
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingTop="16dp" android:paddingBottom="28dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:paddingStart="@dimen/screen_horizontal"
                android:paddingEnd="@dimen/screen_horizontal">

                <ImageView
                    android:id="@+id/imgLogo"
                    android:layout_marginTop="40dp"
                    android:layout_width="130dp"
                    android:layout_height="97dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/app_name"
                    android:scaleType="fitCenter"
                    android:src="@drawable/logo_skyline"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <ImageButton
                    android:id="@+id/btnHome"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@null"
                    android:src="@drawable/ic_home"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView android:id="@+id/tvSkip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end" android:layout_marginEnd="28dp" android:layout_marginTop="0dp" android:text="Bỏ qua  →" android:textColor="@color/auth_blue" android:textSize="16sp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="28dp" android:text="Hoàn tất thông tin tài khoản" android:textColor="@color/auth_blue_dark" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="14dp" android:text="Bổ sung thông tin để cá nhân hoá trải nghiệm và tận hưởng nhiều tiện ích hơn.\nNếu bỏ qua, bạn có thể thêm lại tại mục My Profile." android:textColor="@color/skyline_text_secondary" android:textSize="15sp" android:lineSpacingExtra="4dp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="18dp" android:drawableStart="@drawable/ic_info_auth" android:drawablePadding="8dp" android:text="Vui lòng nhập ít nhất CCCD hoặc Hộ chiếu" android:textColor="@color/auth_blue" android:textSize="14sp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="18dp" android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.46" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mã Quốc gia *" android:textColor="@color/auth_blue" android:textStyle="bold"/><TextView android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="8dp" android:background="@drawable/bg_auth_input" android:drawableEnd="@drawable/ic_dropdown_auth" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp" android:text="+84" android:textColor="@color/auth_blue_dark" android:textSize="16sp"/></LinearLayout>
            <Space android:layout_width="14dp" android:layout_height="1dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.54" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Số điện thoại *" android:textColor="@color/auth_blue" android:textStyle="bold"/><EditText android:id="@+id/edtPhone" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="8dp" android:background="@drawable/bg_auth_input" android:hint="0123456" android:inputType="phone" android:paddingStart="14dp" android:paddingEnd="14dp" android:textColorHint="@color/auth_hint"/></LinearLayout>
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginTop="18dp" android:text="Danh xưng *" android:textColor="@color/auth_blue" android:textStyle="bold"/><TextView android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="8dp" android:background="@drawable/bg_auth_input" android:drawableEnd="@drawable/ic_dropdown_auth" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp" android:text="Bà" android:textColor="@color/auth_blue_dark" android:textSize="16sp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginTop="18dp" android:text="Họ *" android:textColor="@color/auth_blue" android:textStyle="bold"/><EditText android:id="@+id/edtFirstName" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="8dp" android:background="@drawable/bg_auth_input" android:hint="VD: Nguyen" android:paddingStart="14dp" android:textColorHint="@color/auth_hint"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginTop="16dp" android:text="Tên đệm và tên *" android:textColor="@color/auth_blue" android:textStyle="bold"/><EditText android:id="@+id/edtLastName" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="8dp" android:background="@drawable/bg_auth_input" android:hint="VD: Van A" android:paddingStart="14dp" android:textColorHint="@color/auth_hint"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginTop="16dp" android:text="Ngày sinh *" android:textColor="@color/auth_blue" android:textStyle="bold"/><EditText android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="8dp" android:background="@drawable/bg_auth_input" android:drawableEnd="@drawable/ic_calendar_auth" android:hint="DD/MM/YYYY" android:paddingStart="14dp" android:paddingEnd="14dp" android:textColorHint="@color/auth_hint"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginTop="16dp" android:text="Căn cước công dân (CCCD)" android:textColor="@color/auth_blue" android:textStyle="bold"/><EditText android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="8dp" android:background="@drawable/bg_auth_input" android:hint="Nhập 12 chữ số CCCD" android:paddingStart="14dp" android:textColorHint="@color/auth_hint"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginTop="16dp" android:text="Số hộ chiếu" android:textColor="@color/auth_blue" android:textStyle="bold"/><EditText android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="8dp" android:background="@drawable/bg_auth_input" android:hint="VD: E3046VN" android:paddingStart="14dp" android:textColorHint="@color/auth_hint"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginTop="16dp" android:text="Quốc gia *" android:textColor="@color/auth_blue" android:textStyle="bold"/><TextView android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="8dp" android:background="@drawable/bg_auth_input" android:drawableEnd="@drawable/ic_dropdown_auth" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp" android:text="-- Chọn quốc gia --" android:textColor="@color/auth_blue_dark" android:textSize="15sp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginTop="16dp" android:text="Địa chỉ" android:textColor="@color/auth_blue" android:textStyle="bold"/><EditText android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="8dp" android:background="@drawable/bg_auth_input" android:hint="Số nhà, phường/xã, tỉnh/thành phố" android:paddingStart="14dp" android:textColorHint="@color/auth_hint"/>
        <CheckBox android:id="@+id/cbAgree" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="24dp" android:layout_marginEnd="28dp" android:layout_marginTop="18dp" android:buttonTint="@color/auth_blue" android:checked="true" android:text="Tôi đồng ý tham gia Chương trình Skyline, cho phép Công ty TNHH Dấu ấn Mặt Trời cùng các Công ty Thành viên Tập đoàn Skyline xử lý, chia sẻ dữ liệu cá nhân của tôi để quản lý tài khoản, tích lũy điểm thưởng và các mục đích khác theo Chính sách bảo mật." android:textColor="@color/auth_blue_dark" android:textSize="14sp" />
        <Button android:id="@+id/btnContinue" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="18dp" android:background="@drawable/bg_auth_button" android:text="Tiếp tục" android:textAllCaps="false" android:textColor="@color/white" android:textSize="17sp" android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>