<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A50064">

    <!-- MoMo Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/momoHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="14dp"
            android:src="@drawable/ic_close"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thanh toán MoMo"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/momoHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/logo_momo" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="SỐ TIỀN THANH TOÁN"
                        android:textColor="@color/skyline_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="2,450,000đ"
                        android:textColor="#A50064"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="20dp"
                        android:background="#F3F4F6" />

                    <TableLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TableRow android:layout_marginBottom="12dp">
                            <TextView android:text="Nhà cung cấp" android:textSize="13sp" android:textColor="#666" />
                            <TextView android:text="SKYLINE" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/black" android:layout_marginStart="20dp" />
                        </TableRow>

                        <TableRow android:layout_marginBottom="12dp">
                            <TextView android:text="Người thanh toán" android:textSize="13sp" android:textColor="#666" />
                            <TextView android:id="@+id/tvPayerName" android:text="NGUYEN VAN A" android:textSize="13sp" android:textColor="@color/black" android:layout_marginStart="20dp" />
                        </TableRow>

                        <TableRow android:layout_marginBottom="12dp">
                            <TextView android:text="Mã giao dịch" android:textSize="13sp" android:textColor="#666" />
                            <TextView android:id="@+id/tvTransactionId" android:text="2837495201" android:textSize="13sp" android:textColor="@color/black" android:layout_marginStart="20dp" />
                        </TableRow>

                        <TableRow>
                            <TextView android:text="Thời gian" android:textSize="13sp" android:textColor="#666" />
                            <TextView android:id="@+id/tvTime" android:text="20/12/2024 14:30" android:textSize="13sp" android:textColor="@color/black" android:layout_marginStart="20dp" />
                        </TableRow>

                    </TableLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPayMomo"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="32dp"
                        android:backgroundTint="#A50064"
                        android:text="XÁC NHẬN THANH TOÁN"
                        android:textStyle="bold"
                        app:cornerRadius="28dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Giao dịch an toàn và bảo mật với MoMo"
                android:textColor="#E9D5E1"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>