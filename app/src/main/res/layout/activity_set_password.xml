<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_screen">
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingTop="16dp" android:paddingBottom="28dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:paddingStart="@dimen/screen_horizontal"
                android:paddingEnd="@dimen/screen_horizontal">

                <ImageView
                    android:id="@+id/imgLogo"
                    android:layout_marginTop="40dp"
                    android:layout_width="130dp"
                    android:layout_height="97dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/app_name"
                    android:scaleType="fitCenter"
                    android:src="@drawable/logo_skyline"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <ImageButton
                    android:id="@+id/btnHome"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@null"
                    android:src="@drawable/ic_home"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="32dp" android:text="Cài đặt mật khẩu" android:textColor="@color/auth_blue_dark" android:textSize="27sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="28dp" android:text="Mật khẩu của bạn  *" android:textColor="@color/auth_blue" android:textSize="16sp" android:textStyle="bold" />
        <EditText android:id="@+id/edtPassword" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="12dp" android:background="@drawable/bg_auth_input" android:drawableStart="@drawable/ic_lock_auth" android:drawableEnd="@drawable/ic_eye_auth" android:drawablePadding="16dp" android:hint="Nhập mật khẩu của bạn" android:inputType="textPassword" android:paddingStart="18dp" android:paddingEnd="18dp" android:textColorHint="@color/auth_hint" android:textSize="16sp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="28dp" android:text="Xác nhận mật khẩu  *" android:textColor="@color/auth_blue" android:textSize="16sp" android:textStyle="bold" />
        <EditText android:id="@+id/edtConfirm" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="12dp" android:background="@drawable/bg_auth_input" android:drawableStart="@drawable/ic_lock_auth" android:drawableEnd="@drawable/ic_eye_auth" android:drawablePadding="16dp" android:hint="Nhập mật khẩu của bạn" android:inputType="textPassword" android:paddingStart="18dp" android:paddingEnd="18dp" android:textColorHint="@color/auth_hint" android:textSize="16sp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="30dp" android:background="@drawable/bg_info_card" android:orientation="vertical" android:padding="18dp"><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Mật khẩu phải bao gồm:" android:textColor="@color/auth_blue_dark" android:textSize="16sp" /><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="16dp" android:orientation="vertical">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:drawableStart="@drawable/ic_check_small_auth" android:drawablePadding="8dp" android:text="Tối thiểu 8 ký tự" android:textColor="@color/auth_hint" android:textSize="14sp"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:drawableStart="@drawable/ic_check_small_auth" android:drawablePadding="8dp" android:text="Bao gồm chữ hoa, chữ thường, số và ký tự đặc biệt" android:textColor="@color/auth_hint" android:textSize="14sp"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:drawableStart="@drawable/ic_check_small_auth" android:drawablePadding="8dp" android:text="Không chứa khoảng trắng" android:textColor="@color/auth_hint" android:textSize="14sp"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:drawableStart="@drawable/ic_check_small_auth" android:drawablePadding="8dp" android:text="Không trùng với 3 mật khẩu gần nhất" android:textColor="@color/auth_hint" android:textSize="14sp"/>
</LinearLayout></LinearLayout>
        <Button android:id="@+id/btnContinue" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="34dp" android:background="@drawable/bg_auth_button" android:text="Tiếp tục" android:textAllCaps="false" android:textColor="@color/white" android:textSize="17sp" android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>