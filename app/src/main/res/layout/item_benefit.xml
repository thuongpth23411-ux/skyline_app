<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingBottom="12dp">

    <ImageView
        android:id="@+id/imgBenefitIcon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_baggage_small" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="14dp">

        <TextView
            android:id="@+id/tvBenefitTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/skyline_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="true" />

        <TextView
            android:id="@+id/tvBenefitDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/skyline_text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="1dp" />
    </LinearLayout>
</LinearLayout>