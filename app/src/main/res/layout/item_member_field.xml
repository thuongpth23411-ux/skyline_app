<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#F0F2F5"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/field_icon"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_action_circle"
            android:backgroundTint="#F2F5F8"
            android:padding="11dp"
            android:src="@drawable/ic_mail_auth"
            app:tint="@color/skyline_blue" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/field_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.05"
                android:text="LABEL"
                android:textColor="@color/skyline_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/field_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Value text"
                android:textColor="@color/skyline_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edt_field_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:background="@android:color/transparent"
                android:importantForAutofill="no"
                android:inputType="text"
                android:textColor="@color/skyline_text"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <ImageView
            android:id="@+id/img_lock"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_lock_auth"
            android:visibility="gone"
            app:tint="#BDBDBD" />

        <ImageView
            android:id="@+id/img_edit"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_chevron_right"
            android:visibility="gone"
            app:tint="#BDBDBD" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
