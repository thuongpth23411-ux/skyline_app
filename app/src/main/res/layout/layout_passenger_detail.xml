<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="24dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin hành khách"
                android:textColor="@color/skyline_text"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/btn_edit_mode"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_edit"
                app:layout_constraintBottom_toBottomOf="@id/tv_detail_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_detail_title"
                app:tint="@color/skyline_teal" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_marginTop="12dp"
            android:background="@color/skyline_teal" />

        <!-- VIEW MODE CONTAINER -->
        <LinearLayout
            android:id="@+id/layout_view_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HỌ TÊN"
                android:textColor="@color/skyline_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tv_view_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="(Bà) PHAM THI HOAI THUONG"
                android:textColor="@color/skyline_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="SỐ ĐIỆN THOẠI"
                android:textColor="@color/skyline_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tv_view_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0987 654 321"
                android:textColor="@color/skyline_text"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="SỐ CCCD / HỘ CHIẾU"
                android:textColor="@color/skyline_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tv_view_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0645 8275 8294"
                android:textColor="@color/skyline_text"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="NGÀY SINH"
                android:textColor="@color/skyline_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tv_view_dob"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="05/08/2005"
                android:textColor="@color/skyline_text"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="EMAIL"
                android:textColor="@color/skyline_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tv_view_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="thaottt23411@st.uel.edu.vn"
                android:textColor="@color/skyline_text"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- EDIT MODE CONTAINER -->
        <LinearLayout
            android:id="@+id/layout_edit_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HỌ VÀ TÊN"
                android:textColor="@color/skyline_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edt_edit_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_auth_input"
                android:paddingHorizontal="12dp"
                android:textColor="@color/skyline_text"
                android:textSize="15sp"
                android:inputType="textCapCharacters" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="SỐ ĐIỆN THOẠI"
                android:textColor="@color/skyline_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edt_edit_phone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_auth_input"
                android:paddingHorizontal="12dp"
                android:textColor="@color/skyline_text"
                android:textSize="15sp"
                android:inputType="phone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="SỐ CCCD / HỘ CHIẾU"
                android:textColor="@color/skyline_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edt_edit_id"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_auth_input"
                android:paddingHorizontal="12dp"
                android:textColor="@color/skyline_text"
                android:textSize="15sp"
                android:inputType="number" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="NGÀY SINH"
                android:textColor="@color/skyline_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edt_edit_dob"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_auth_input"
                android:paddingHorizontal="12dp"
                android:textColor="@color/skyline_text"
                android:textSize="15sp"
                android:focusable="false"
                android:clickable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="EMAIL"
                android:textColor="@color/skyline_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edt_edit_email"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_auth_input"
                android:paddingHorizontal="12dp"
                android:textColor="@color/skyline_text"
                android:textSize="15sp"
                android:inputType="textEmailAddress" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_changes"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/skyline_blue_dark"
                android:text="Lưu thay đổi"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_close_detail"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Đóng"
            android:textAllCaps="false"
            android:textColor="@color/skyline_text_secondary" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
