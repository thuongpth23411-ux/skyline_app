    <string name="terms_date">Tháng 10, 2023</string>
    <string name="terms_section_1">1. Quy định chung</string>
    <string name="terms_section_1_content">Chương trình Hội viên Skyline được thiết kế nhằm mang lại những trải nghiệm ưu việt và quyền lợi đặc quyền cho khách hàng thân thiết. Bằng cách đăng ký tham gia, người dùng đồng ý tuân thủ toàn bộ các quy định được nêu tại đây.</string>
    <string name="terms_section_2">2. Quyền lợi hội viên</string>
    <string name="terms_section_2_content">Chương trình bao gồm các hạng thẻ: Đồng, Bạc, Vàng và Kim cương. Mỗi hạng thẻ sẽ mang lại những đặc quyền riêng biệt về tích lũy điểm, ưu đãi dịch vụ và trải nghiệm ưu tiên tùy theo mức độ gắn kết của hội viên.</string>
    <string name="terms_rank_bronze">Đồng</string>
    <string name="terms_rank_silver">Bạc</string>
    <string name="terms_rank_gold">Vàng</string>
    <string name="terms_rank_diamond">Kim cương</string>
    <string name="terms_section_3">3. Nghĩa vụ hội viên</string>
    <string name="terms_sub_security">Bảo mật tài khoản</string>
    <string name="terms_sub_security_content">Hội viên có trách nhiệm bảo mật thông tin đăng nhập và không chia sẻ tài khoản cho bên thứ ba.</string>
    <string name="terms_sub_info">Thông tin chính xác</string>
    <string name="terms_sub_info_content">Cung cấp thông tin cá nhân chính xác để đảm bảo quyền lợi và nhận thông báo kịp thời.</string>
    <string name="terms_section_4">4. Chính sách bảo mật</string>
    <string name="terms_section_4_content">Chúng tôi cam kết bảo vệ dữ liệu cá nhân của bạn theo tiêu chuẩn quốc tế. Thông tin chỉ được sử dụng để cá nhân hóa dịch vụ và cải thiện trải nghiệm hội viên. Chi tiết vui lòng xem tại Chính sách quyền riêng tư.</string>
    <string name="terms_section_5">5. Thay đổi điều khoản</string>
    <string name="terms_section_5_content">Công ty có quyền sửa đổi hoặc cập nhật các điều khoản này bất kỳ lúc nào. Thông báo sẽ được gửi qua ứng dụng hoặc email trước khi các thay đổi có hiệu lực.</string>
    <string name="terms_footer_question">Bạn có thắc mắc về các điều khoản này?</string>

