<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="NavItemStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="NavIconStyle">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:drawablePadding">6dp</item>
    </style>

    <style name="NavTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:textColor">@color/skyline_blue</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="SectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/skyline_text</item>
    </style>

    <style name="BottomNavItemStyle" parent="NavItemStyle">
        <item name="android:drawablePadding">4dp</item>
        <item name="android:textColor">@color/nav_item_color</item>
        <item name="android:textSize">11sp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
    </style>

    <style name="FeatureTitle">
        <item name="android:textColor">@color/skyline_text</item>
        <item name="android:textSize">19sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="FeatureBody">
        <item name="android:textColor">@color/skyline_text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <!-- Custom Date Picker Theme -->
    <style name="CustomDatePickerTheme" parent="ThemeOverlay.Material3.MaterialCalendar">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/white</item>
        <item name="colorSurfaceContainer">@color/white</item>
        <item name="colorSurfaceContainerHigh">@color/white</item>
        <item name="colorSurfaceContainerHighest">@color/white</item>
        <item name="colorSurfaceContainerLow">@color/white</item>
        <item name="colorSurfaceContainerLowest">@color/white</item>

        <item name="colorPrimary">@color/skyline_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSurface">@color/skyline_blue_dark</item>
        <item name="colorOnSurfaceVariant">@color/skyline_blue_dark</item>
        <item name="colorSecondary">@color/skyline_blue_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="materialCalendarStyle">@style/CustomMaterialCalendarStyle</item>
        <item name="materialCalendarHeaderLayout">@style/CustomCalendarHeaderLayout</item>
        <item name="materialCalendarHeaderTitle">@style/CustomCalendarHeaderTitle</item>
        <item name="materialCalendarHeaderSelection">@style/CustomCalendarHeaderSelection</item>
        <item name="materialCalendarHeaderToggleButton">@style/HideViewStyle</item>

        <item name="buttonBarPositiveButtonStyle">@style/CustomPositiveButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/CustomNegativeButtonStyle</item>
    </style>

    <style name="CustomMaterialCalendarStyle" parent="Widget.Material3.MaterialCalendar">
        <item name="android:background">@color/white</item>
    </style>

    <style name="CustomCalendarHeaderLayout" parent="Widget.Material3.MaterialCalendar.HeaderLayout">
        <item name="android:background">@color/white</item>
        <item name="backgroundTint">@color/white</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>

    <style name="CustomCalendarHeaderTitle" parent="Widget.Material3.MaterialCalendar.HeaderTitle">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/skyline_blue_dark</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <style name="CustomCalendarHeaderSelection" parent="Widget.Material3.MaterialCalendar.HeaderSelection">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/skyline_blue_dark</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">16dp</item>
    </style>

    <style name="HideViewStyle">
        <item name="android:visibility">gone</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
    </style>

    <style name="CustomPositiveButtonStyle" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/skyline_blue_dark</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <style name="CustomNegativeButtonStyle" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:visibility">gone</item>
    </style>

    <style name="FilterChipStyle" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/filter_chip_bg_selector</item>
        <item name="chipStrokeColor">#D1D5DB</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/filter_chip_text_selector</item>
        <item name="chipIconVisible">false</item>
        <item name="checkedIconVisible">false</item>
        <item name="showMotionSpec">@null</item>
        <item name="hideMotionSpec">@null</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="rippleColor">@color/skyline_blue_light</item>
    </style>
</resources>
