<resources>
    <style name="NavItemStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>
    <style name="NavIconStyle">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
    </style>
    <style name="NavTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:textColor">@color/skyline_blue</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="BottomNavItemStyle" parent="NavItemStyle">
        <item name="android:drawablePadding">5dp</item>
        <item name="android:textColor">@color/skyline_blue</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>